<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>0x-flights admin</title>
  <style>{{{styles}}}</style>
</head>
<body>
  <div class="page-shell">
    <header class="hero">
      <div>
        <p class="eyebrow">Control room</p>
        <h1>0x-flights admin</h1>
        <p class="subtitle">Monitor users, trackers, worker health and delivery pipeline in one place.</p>
      </div>
      <p class="footer">Loaded {{now}} · <a href="/adminpage">Refresh</a></p>
    </header>

    <div class="stats">
      <div class="stat"><div class="stat-label">Users</div><div class="stat-value">{{stats.users}}</div></div>
      <div class="stat"><div class="stat-label">Active trackers</div><div class="stat-value">{{stats.activeTrackers}}</div></div>
      <div class="stat"><div class="stat-label">Price checks</div><div class="stat-value">{{stats.priceChecks}}</div></div>
      <div class="stat"><div class="stat-label">Notifications</div><div class="stat-value">{{stats.notifications}}</div></div>
    </div>

    <nav class="tabs" role="tablist" aria-label="Admin tabs">
      <a class="tab {{#if (eq activeTab 'overview')}}is-active{{/if}}" href="/adminpage?tab=overview&usersPage={{usersPagination.page}}&trackersPage={{trackersPagination.page}}&pricesPage={{pricesPagination.page}}&notificationsPage={{notificationsPagination.page}}">Overview</a>
      <a class="tab {{#if (eq activeTab 'users')}}is-active{{/if}}" href="/adminpage?tab=users&usersPage={{usersPagination.page}}&trackersPage={{trackersPagination.page}}&pricesPage={{pricesPagination.page}}&notificationsPage={{notificationsPagination.page}}">Users <span class="tab-count">{{usersPagination.total}}</span></a>
      <a class="tab {{#if (eq activeTab 'trackers')}}is-active{{/if}}" href="/adminpage?tab=trackers&usersPage={{usersPagination.page}}&trackersPage={{trackersPagination.page}}&pricesPage={{pricesPagination.page}}&notificationsPage={{notificationsPagination.page}}">Trackers <span class="tab-count">{{trackersPagination.total}}</span></a>
      <a class="tab {{#if (eq activeTab 'prices')}}is-active{{/if}}" href="/adminpage?tab=prices&usersPage={{usersPagination.page}}&trackersPage={{trackersPagination.page}}&pricesPage={{pricesPagination.page}}&notificationsPage={{notificationsPagination.page}}">Prices <span class="tab-count">{{pricesPagination.total}}</span></a>
      <a class="tab {{#if (eq activeTab 'notifications')}}is-active{{/if}}" href="/adminpage?tab=notifications&usersPage={{usersPagination.page}}&trackersPage={{trackersPagination.page}}&pricesPage={{pricesPagination.page}}&notificationsPage={{notificationsPagination.page}}">Notifications <span class="tab-count">{{notificationsPagination.total}}</span></a>
    </nav>

    <section class="tab-panel {{#if (eq activeTab 'overview')}}is-active{{/if}}" data-panel="overview">
      <div class="panel-head">
        <div>
          <h2>Worker status</h2>
          <p class="panel-help">Live metrics from price and notification workers — updated after each cycle.</p>
        </div>
      </div>

      <div class="table-shell" style="margin-bottom:1.5rem">
        <table>
          <thead><tr><th>Worker</th><th>Last run</th><th>Freshness</th><th>Action</th></tr></thead>
          <tbody>
            <tr>
              <td><b>worker-prices</b></td>
              <td>{{workerStatus.lastRunText}}</td>
              <td>
                {{#if (eq workerStatus.freshness "ok")}}
                  <span class="badge active">ok</span>
                {{else}}
                  {{#if (eq workerStatus.freshness "stale")}}
                    <span class="badge off">stale</span>
                  {{else}}
                    <span class="dim">n/a</span>
                  {{/if}}
                {{/if}}
              </td>
              <td>
                <form method="POST" action="/adminpage/workers/prices/run-now" style="display:inline">
                  <button class="btn btn-blue">{{#if workerStatus.forcePending}}Pending…{{else}}Run now{{/if}}</button>
                </form>
              </td>
            </tr>
            <tr>
              <td><b>worker-notifications</b></td>
              <td>{{workerStatus.notifWorker.lastRunText}}</td>
              <td><span class="dim">—</span></td>
              <td><span class="dim">—</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="metrics-grid">
        <div class="metrics-group">
          <div class="metrics-group-title">Price worker — last cycle</div>
          {{#if workerStatus.lastCycle}}
            <div class="metrics-row">
              <div class="metric-card"><div class="metric-label">Total cycles</div><div class="metric-val">{{workerStatus.lastCycle.cycleCount}}</div></div>
              <div class="metric-card"><div class="metric-label">Duration</div><div class="metric-val">{{workerStatus.lastCycle.durationText}}</div></div>
              <div class="metric-card"><div class="metric-label">Trackers</div><div class="metric-val">{{workerStatus.lastCycle.trackers}}</div></div>
              <div class="metric-card"><div class="metric-label">Routes</div><div class="metric-val">{{workerStatus.lastCycle.routes}}</div></div>
              <div class="metric-card"><div class="metric-label">Prices saved</div><div class="metric-val">{{workerStatus.lastCycle.prices}}</div></div>
              <div class="metric-card"><div class="metric-label">Notifs sent</div><div class="metric-val">{{workerStatus.lastCycle.notifs}}</div></div>
            </div>
          {{else}}
            <p class="dim" style="padding:0.75rem 0">No cycle data yet — worker hasn't run since deploy.</p>
          {{/if}}
        </div>

        <div class="metrics-group">
          <div class="metrics-group-title">Notification worker — all time</div>
          <div class="metrics-row">
            <div class="metric-card good"><div class="metric-label">Jobs completed</div><div class="metric-val">{{workerStatus.notifWorker.jobsCompleted}}</div></div>
            <div class="metric-card {{#if workerStatus.notifWorker.jobsFailed}}bad{{/if}}"><div class="metric-label">Jobs failed</div><div class="metric-val">{{workerStatus.notifWorker.jobsFailed}}</div></div>
          </div>
        </div>
      </div>
    </section>

    <section class="tab-panel {{#if (eq activeTab 'users')}}is-active{{/if}}" data-panel="users">
      <div class="panel-head">
        <div>
          <h2>Users</h2>
          <p class="panel-help">What is happening: shows user base and lets you ban (disable all trackers) or unban (re-enable trackers).</p>
        </div>
      </div>
      <div class="table-shell">
        <table>
          <thead><tr><th>ID</th><th>Telegram ID</th><th>Username</th><th>Name</th><th>Trackers (all/active)</th><th>Joined</th><th>Action</th><th></th></tr></thead>
          <tbody>
            {{#if allUsers.length}}
              {{#each allUsers}}
                <tr>
                  <td>#{{id}}</td>
                  <td>{{telegramId}}</td>
                  <td>{{username}}</td>
                  <td>{{fullName}}</td>
                  <td>{{trackerCount}} / <span class="good">{{activeTrackerCount}}</span></td>
                  <td>{{joinedDate}}</td>
                  <td>
                    {{#if canBan}}
                      <form method="POST" action="/adminpage/users/{{id}}/ban" style="display:inline">
                        <button class="btn btn-red" onclick="return confirm('Ban user #{{id}} - deactivate all their trackers?')">Ban</button>
                      </form>
                    {{else}}
                      {{#if canUnban}}
                        <form method="POST" action="/adminpage/users/{{id}}/unban" style="display:inline">
                          <button class="btn btn-blue" onclick="return confirm('Unban user #{{id}} - reactivate trackers?')">Unban</button>
                        </form>
                      {{else}}
                        <span class="dim">-</span>
                      {{/if}}
                    {{/if}}
                  </td>
                  <td>
                    <button
                      class="btn btn-ghost js-details"
                      data-title="User #{{id}}"
                      data-details="Telegram ID::{{telegramId}}||Username::{{username}}||Full name::{{fullName}}||Total trackers::{{trackerCount}}||Active trackers::{{activeTrackerCount}}||Joined::{{joinedDate}}||Action state::{{#if canBan}}can ban{{else}}{{#if canUnban}}can unban{{else}}no actions{{/if}}{{/if}}"
                    >Details</button>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr><td colspan="8" class="empty">no data</td></tr>
            {{/if}}
          </tbody>
        </table>
        <div class="pager">
          <a class="btn btn-ghost {{#if (eq usersPagination.page 1)}}is-disabled{{/if}}" href="{{usersPrevHref}}">Prev</a>
          <span class="pager-info">Page {{usersPagination.page}} / {{usersPagination.totalPages}} · {{usersPagination.total}} total</span>
          <a class="btn btn-ghost {{#if (eq usersPagination.page usersPagination.totalPages)}}is-disabled{{/if}}" href="{{usersNextHref}}">Next</a>
        </div>
      </div>
    </section>

    <section class="tab-panel {{#if (eq activeTab 'trackers')}}is-active{{/if}}" data-panel="trackers">
      <div class="panel-head">
        <div>
          <h2>Trackers</h2>
          <p class="panel-help">What is happening: active tracker set used by worker-prices for route checks and notifications.</p>
        </div>
      </div>
      <div class="table-shell">
        <table>
          <thead><tr><th>ID</th><th>User</th><th>Route</th><th>Date</th><th>Threshold</th><th>Latest price</th><th>Status</th><th>Action</th><th></th></tr></thead>
          <tbody>
            {{#if allTrackers.length}}
              {{#each allTrackers}}
                <tr class="{{#unless isActive}}inactive{{/unless}}">
                  <td>#{{id}}</td>
                  <td>{{userLabel}}</td>
                  <td><b>{{route}}</b></td>
                  <td>{{departureDate}}</td>
                  <td>{{thresholdText}}</td>
                  <td><span class="price-tag">{{latestPriceText}}</span></td>
                  <td><span class="badge {{#if isActive}}active{{else}}off{{/if}}">{{#if isActive}}active{{else}}off{{/if}}</span></td>
                  <td>
                    {{#if isActive}}
                      <form method="POST" action="/adminpage/trackers/{{id}}/deactivate" style="display:inline">
                        <button class="btn btn-red" onclick="return confirm('Deactivate #{{id}}?')">Off</button>
                      </form>
                    {{else}}
                      <form method="POST" action="/adminpage/trackers/{{id}}/activate" style="display:inline">
                        <button class="btn btn-blue" onclick="return confirm('Activate #{{id}}?')">On</button>
                      </form>
                    {{/if}}
                  </td>
                  <td>
                    <button
                      class="btn btn-ghost js-details"
                      data-title="Tracker #{{id}}"
                      data-details="User::{{userLabel}}||Route::{{route}}||Departure::{{departureDate}}||Threshold::{{thresholdText}}||Latest price::{{latestPriceText}}||Status::{{#if isActive}}active{{else}}off{{/if}}"
                    >Details</button>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr><td colspan="9" class="empty">no data</td></tr>
            {{/if}}
          </tbody>
        </table>
        <div class="pager">
          <a class="btn btn-ghost {{#if (eq trackersPagination.page 1)}}is-disabled{{/if}}" href="{{trackersPrevHref}}">Prev</a>
          <span class="pager-info">Page {{trackersPagination.page}} / {{trackersPagination.totalPages}} · {{trackersPagination.total}} total</span>
          <a class="btn btn-ghost {{#if (eq trackersPagination.page trackersPagination.totalPages)}}is-disabled{{/if}}" href="{{trackersNextHref}}">Next</a>
        </div>
      </div>
    </section>

    <section class="tab-panel {{#if (eq activeTab 'prices')}}is-active{{/if}}" data-panel="prices">
      <div class="panel-head">
        <div>
          <h2>Recent price checks</h2>
          <p class="panel-help">What is happening: latest snapshots from provider fetches that feed thresholds and notifications.</p>
        </div>
      </div>
      <div class="table-shell">
        <table>
          <thead><tr><th>Tracker</th><th>Route</th><th>Price</th><th>Source</th><th>Fetched at</th><th></th></tr></thead>
          <tbody>
            {{#if recentPrices.length}}
              {{#each recentPrices}}
                <tr>
                  <td>#{{trackerId}}</td>
                  <td>{{route}}</td>
                  <td class="price-tag">{{priceText}}</td>
                  <td>{{source}}</td>
                  <td>{{fetchedAt}}</td>
                  <td>
                    <button
                      class="btn btn-ghost js-details"
                      data-title="Price check: tracker #{{trackerId}}"
                      data-details="Tracker::#{{trackerId}}||Route::{{route}}||Price::{{priceText}}||Source::{{source}}||Fetched at::{{fetchedAt}}"
                    >Details</button>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr><td colspan="6" class="empty">no data</td></tr>
            {{/if}}
          </tbody>
        </table>
        <div class="pager">
          <a class="btn btn-ghost {{#if (eq pricesPagination.page 1)}}is-disabled{{/if}}" href="{{pricesPrevHref}}">Prev</a>
          <span class="pager-info">Page {{pricesPagination.page}} / {{pricesPagination.totalPages}} · {{pricesPagination.total}} total</span>
          <a class="btn btn-ghost {{#if (eq pricesPagination.page pricesPagination.totalPages)}}is-disabled{{/if}}" href="{{pricesNextHref}}">Next</a>
        </div>
      </div>
    </section>

    <section class="tab-panel {{#if (eq activeTab 'notifications')}}is-active{{/if}}" data-panel="notifications">
      <div class="panel-head">
        <div>
          <h2>Notifications log</h2>
          <p class="panel-help">What is happening: send queue outcomes, whether message was delivered or still pending.</p>
        </div>
      </div>
      <div class="table-shell">
        <table>
          <thead><tr><th>User</th><th>Route</th><th>Price</th><th>Status</th><th>Created at</th><th></th></tr></thead>
          <tbody>
            {{#if recentNotifs.length}}
              {{#each recentNotifs}}
                <tr>
                  <td>{{userLabel}}</td>
                  <td>{{route}}</td>
                  <td class="price-tag">{{priceText}}</td>
                  <td>
                    {{#if isSent}}
                      <span class="badge active">sent</span>
                    {{else}}
                      <span class="badge off">pending</span>
                    {{/if}}
                  </td>
                  <td>{{createdAt}}</td>
                  <td>
                    <button
                      class="btn btn-ghost js-details"
                      data-title="Notification event"
                      data-details="User::{{userLabel}}||Route::{{route}}||Price::{{priceText}}||Status::{{#if isSent}}sent{{else}}pending{{/if}}||Created at::{{createdAt}}"
                    >Details</button>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr><td colspan="6" class="empty">no data</td></tr>
            {{/if}}
          </tbody>
        </table>
        <div class="pager">
          <a class="btn btn-ghost {{#if (eq notificationsPagination.page 1)}}is-disabled{{/if}}" href="{{notificationsPrevHref}}">Prev</a>
          <span class="pager-info">Page {{notificationsPagination.page}} / {{notificationsPagination.totalPages}} · {{notificationsPagination.total}} total</span>
          <a class="btn btn-ghost {{#if (eq notificationsPagination.page notificationsPagination.totalPages)}}is-disabled{{/if}}" href="{{notificationsNextHref}}">Next</a>
        </div>
      </div>
    </section>
  </div>

  <div class="modal" id="detail-modal" aria-hidden="true">
    <div class="modal-backdrop" data-close-modal></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="detail-modal-title">
      <div class="modal-head">
        <h3 id="detail-modal-title">Details</h3>
        <button class="btn btn-ghost" data-close-modal>Close</button>
      </div>
      <div class="modal-body" id="detail-modal-body"></div>
    </div>
  </div>

  <script>
    (() => {
      const modal = document.getElementById('detail-modal')
      const modalTitle = document.getElementById('detail-modal-title')
      const modalBody = document.getElementById('detail-modal-body')
      if (!modal || !modalTitle || !modalBody) return

      function openModal(title, detailsRaw) {
        modalTitle.textContent = title || 'Details'
        modalBody.innerHTML = ''
        const details = String(detailsRaw || '').split('||').map((x) => x.trim()).filter(Boolean)
        details.forEach((line) => {
          const [k, ...rest] = line.split('::')
          const v = rest.join('::') || '-'
          const row = document.createElement('div')
          row.className = 'detail-row'
          row.innerHTML = `<span class="detail-key"></span><span class="detail-val"></span>`
          row.querySelector('.detail-key').textContent = k || 'Field'
          row.querySelector('.detail-val').textContent = v
          modalBody.appendChild(row)
        })

        modal.classList.add('is-open')
        modal.setAttribute('aria-hidden', 'false')
      }

      function closeModal() {
        modal.classList.remove('is-open')
        modal.setAttribute('aria-hidden', 'true')
      }

      document.querySelectorAll('.js-details').forEach((btn) => {
        btn.addEventListener('click', () => {
          openModal(btn.getAttribute('data-title'), btn.getAttribute('data-details'))
        })
      })

      document.querySelectorAll('[data-close-modal]').forEach((el) => {
        el.addEventListener('click', closeModal)
      })

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal()
      })
    })()
  </script>
</body>
</html>
